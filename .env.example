# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=jdbc:mysql://localhost:3306/internship_portal
DATABASE_USERNAME=root
DATABASE_PASSWORD=
MYSQL_ROOT_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=

# ── Mail (Gmail) ──────────────────────────────────────────────────────────────
# Use a Gmail App Password (Google Account → Security → 2FA → App Passwords)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-app-password
MAIL_HOST_NAME=your-email@gmail.com

# ── File Storage ──────────────────────────────────────────────────────────────
# Absolute path to the directory where uploads will be stored
ROOT=/absolute/path/to/storage

# ── Certificate Assets ────────────────────────────────────────────────────────
ORGANIZATIONLOGOPATH=/absolute/path/to/logo.png
OFFICIALSEALPATH=/absolute/path/to/seal.png
INSTRUCTORSIGNATUREPATH=/absolute/path/to/instructor-signature.png
DIRECTORSIGNATUREPATH=/absolute/path/to/director-signature.png
CERTIFICATETEMPLATEPATH=/absolute/path/to/certificate-template.png

# ── URL ───────────────────────────────────────────────────────────────────────
URLPREFIX=http://localhost:8080/internship-portal

# ── Admin Seed ────────────────────────────────────────────────────────────────
# Credentials for the admin account auto-created on first boot
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_EMAIL=
ADMIN_PHONE_NUMBER=
