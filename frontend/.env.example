# Frontend environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Base URL of the Spring Boot API (no trailing slash)
API_BASE_URL=http://localhost:8080/internship-portal/api/v1

# Optional: override API URL specifically for production builds (ng build --configuration production)
# If omitted, API_BASE_URL is used for both dev and prod builds.
# API_BASE_URL_PROD=https://your-prod-domain.com/internship-portal/api/v1
